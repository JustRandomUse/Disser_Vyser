# External API Key (required)
SENSOR_API_KEY=your-api-key-here

# Server port (optional, default: 8080)
PORT=8080

# Allowed CORS origins (optional, comma-separated)
# For local development, defaults to localhost ports
# For production, set to your frontend domain(s)
# Example: https://your-frontend.vercel.app,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
