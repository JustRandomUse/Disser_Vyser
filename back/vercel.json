{
  "version": 2,
  "builds": [
    {
      "src": "cmd/server/main.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "cmd/server/main.go"
    }
  ],
  "env": {
    "SENSOR_API_KEY": "@sensor_api_key",
    "ALLOWED_ORIGINS": "@allowed_origins"
  }
}
